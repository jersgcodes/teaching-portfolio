{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://jersgcodes.com/schema/v1/lesson.json",
  "title": "Lesson",
  "description": "A concrete takeaway, often cross-cutting. Examples: 'Cap-aware AI scoring', 'Privacy-first PDF parsing'.",
  "type": "object",
  "required": [
    "title",
    "slug",
    "summary",
    "visibility",
    "workflow_stages",
    "outcomes",
    "body",
    "authors"
  ],
  "additionalProperties": false,
  "properties": {
    "title": { "type": "string", "minLength": 5, "maxLength": 80 },
    "slug": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*[a-z0-9]$" },
    "summary": {
      "type": "string",
      "minLength": 20,
      "maxLength": 200,
      "description": "Plain-English one-paragraph hook."
    },
    "visibility": {
      "type": "string",
      "enum": ["public", "mentioned", "hidden"]
    },
    "workflow_stages": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": ["define", "delegate", "direct", "discern", "document"]
      }
    },
    "outcomes": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": ["save_time", "improve_quality", "enable_new", "reduce_risk"]
      }
    },
    "related_projects": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9][a-z0-9-]*[a-z0-9]$",
        "description": "Project slug references."
      }
    },
    "related_concepts": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9][a-z0-9-]*[a-z0-9]$"
      }
    },
    "body": {
      "type": "string",
      "minLength": 100,
      "description": "Markdown content."
    },
    "authors": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["role", "by", "when"],
        "additionalProperties": false,
        "properties": {
          "role": { "type": "string", "enum": ["drafted", "reviewed", "edited"] },
          "by": { "type": "string", "minLength": 2 },
          "when": { "type": "string", "format": "date" }
        }
      }
    },
    "last_updated": { "type": "string", "format": "date" }
  }
}
